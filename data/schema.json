{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/cruise-prices-pipeline/schema.json",
  "title": "CruiseVoyage",
  "description": "Normalized schema for a single cruise voyage record, shared across all cruise lines",
  "type": "object",
  "required": [
    "scrape_date",
    "scrape_timestamp",
    "cruise_line",
    "voyage_id",
    "voyage_name",
    "ship_name",
    "departure_port",
    "departure_date",
    "duration_nights",
    "region",
    "cabin_categories",
    "voyage_url"
  ],
  "properties": {
    "scrape_date": {
      "type": "string",
      "format": "date",
      "description": "Date the data was scraped (YYYY-MM-DD)"
    },
    "scrape_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Full ISO 8601 timestamp of when the record was scraped"
    },
    "cruise_line": {
      "type": "string",
      "enum": ["explora_journeys", "oceania_cruises"],
      "description": "Identifier for the cruise line"
    },
    "voyage_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this voyage (sourced from the cruise line or derived)"
    },
    "voyage_name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the voyage/itinerary"
    },
    "ship_name": {
      "type": "string",
      "description": "Name of the ship operating this voyage"
    },
    "departure_port": {
      "type": "string",
      "description": "Port of departure (city name)"
    },
    "departure_date": {
      "type": "string",
      "format": "date",
      "description": "Departure date (YYYY-MM-DD)"
    },
    "return_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Return/end date (YYYY-MM-DD), null if unknown"
    },
    "duration_nights": {
      "type": "integer",
      "minimum": 1,
      "description": "Duration of the voyage in nights"
    },
    "region": {
      "type": "string",
      "description": "Geographic region (e.g. Mediterranean, Caribbean, Northern Europe)"
    },
    "cabin_categories": {
      "type": "array",
      "minItems": 1,
      "description": "Pricing and availability by cabin category",
      "items": {
        "type": "object",
        "required": ["category_code", "category_name", "price_per_person", "currency", "availability"],
        "properties": {
          "category_code": {
            "type": "string",
            "description": "Cruise line's cabin category code (e.g. IS, OC, PS)"
          },
          "category_name": {
            "type": "string",
            "description": "Human-readable cabin category name (e.g. Interior Studio, Ocean View, Penthouse Suite)"
          },
          "price_per_person": {
            "type": ["number", "null"],
            "minimum": 0,
            "description": "Price per person in the given currency; null if price unavailable"
          },
          "currency": {
            "type": "string",
            "pattern": "^[A-Z]{3}$",
            "description": "ISO 4217 currency code (e.g. USD, EUR, GBP)"
          },
          "availability": {
            "type": "string",
            "enum": ["available", "waitlist", "sold_out", "unknown"],
            "description": "Booking availability status"
          }
        }
      }
    },
    "voyage_url": {
      "type": "string",
      "format": "uri",
      "description": "Full URL to the voyage detail page"
    }
  },
  "additionalProperties": false
}
